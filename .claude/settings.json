{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "cd \"$CLAUDE_PROJECT_DIR/apps/desktop\" 2>/dev/null && bun run format 2>&1 || true",
            "timeout": 60,
            "statusMessage": "Running prettier on apps/desktop/src..."
          }
        ]
      }
    ]
  }
}
